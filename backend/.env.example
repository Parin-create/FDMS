# ----------------------------------------------------------------------------
# FDMS backend environment configuration.
# Copy to ".env" for local (non-Docker) runs. In Azure these values are supplied
# by the environment / Key Vault (ADR-005); never commit real secrets.
# ----------------------------------------------------------------------------

# Application
APP_NAME=FDMS API
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Observability — Azure Application Insights (OpenTelemetry)
# Local dev: paste the connection string here, or leave EMPTY to disable telemetry.
# Azure: leave EMPTY and store it in Key Vault as secret "fdms-appinsights-connection-string".
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Master on/off switch (telemetry only activates when a connection string is also present).
TELEMETRY_ENABLED=true

# Database — Azure PostgreSQL Flexible Server (asyncpg)
# In Azure, these are injected from Key Vault via the Container App's environment
# (managed identity). Never commit real credentials.
#   Local dev example:  POSTGRES_HOST=localhost   POSTGRES_SSLMODE=prefer
#   Azure example:      POSTGRES_HOST=<server-name>.postgres.database.azure.com
#                       POSTGRES_SSLMODE=require   (or verify-full with a CA)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fdms
POSTGRES_PASSWORD=fdms
POSTGRES_DB=fdms
# TLS: disable | allow | prefer | require | verify-ca | verify-full
POSTGRES_SSLMODE=prefer
# Optional CA bundle (PEM) path for verify-ca / verify-full (e.g. DigiCert Global Root G2).
POSTGRES_SSL_ROOT_CERT=
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10

# Azure Key Vault (secret retrieval)
# Leave EMPTY for local development — secrets are read from this .env file.
# In Azure, set to your vault URI; the app fetches secrets via managed identity
# (DefaultAzureCredential) and caches them for the process lifetime.
#   Example: KEY_VAULT_URL=https://fdms-kv.vault.azure.net
# Expected secret names in the vault (config field -> Key Vault secret):
#   postgres_password                    -> fdms-postgres-password
#   azure_storage_connection_string      -> fdms-storage-connection-string
#   applicationinsights_connection_string -> fdms-appinsights-connection-string
KEY_VAULT_URL=

# Azure Blob Storage
# Local dev: paste the account connection string here.
# Azure: leave EMPTY and store it in Key Vault as secret "fdms-storage-connection-string";
# it is retrieved automatically at startup via managed identity.
AZURE_STORAGE_CONNECTION_STRING=
# Optional managed-identity auth alternative (used when no connection string is set):
#   AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
AZURE_STORAGE_ACCOUNT_URL=
# Container names (already provisioned in the account).
BLOB_CONTAINER_DOCUMENTS=documents
BLOB_CONTAINER_THUMBNAILS=thumbnails
BLOB_CONTAINER_TEMP=temp
# Transient-failure retry attempts (exponential backoff by the SDK).
AZURE_STORAGE_MAX_RETRIES=3

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Authentication — Microsoft Entra ID (ADR-005)
# Directory (tenant) GUID for single-tenant, or "organizations"/"common" for multi-tenant.
ENTRA_TENANT_ID=
# Client (application) ID of the API app registration (the token audience).
ENTRA_CLIENT_ID=
# Optional audience override, e.g. api://<api-client-id>. Defaults to ENTRA_CLIENT_ID.
ENTRA_API_AUDIENCE=
# Default RBAC role for JIT-provisioned users: TenantAdmin|Manager|Contributor|Viewer|Guest
AUTH_DEFAULT_ROLE=Viewer
# Auto-create a tenant record on first sign-in from an unknown directory (dev convenience).
AUTH_AUTO_PROVISION_TENANT=true
