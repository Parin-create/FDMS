# Optional overrides for docker-compose. Copy to "infrastructure/.env".
# Docker Compose auto-loads a .env file located next to the compose file.

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=true

# PostgreSQL credentials (shared by the db and backend services).
POSTGRES_USER=fdms
POSTGRES_PASSWORD=fdms
POSTGRES_DB=fdms

# Allowed CORS origin for the browser app served by the frontend container.
CORS_ORIGINS=http://localhost:8080
