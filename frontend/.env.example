# FDMS frontend environment configuration.
# Copy to ".env" for local development. Only VITE_-prefixed vars are exposed.

# Base URL for API calls. In dev the Vite proxy forwards /api to the backend;
# in Docker, nginx proxies /api to the backend service.
VITE_API_BASE_URL=/api/v1

# Display name shown in the UI shell.
VITE_APP_NAME=FDMS

# --- Microsoft Entra ID (MSAL) ---
# SPA app registration (Single-page application) client id.
VITE_ENTRA_CLIENT_ID=
# Directory (tenant) GUID, or "organizations" / "common" for multi-tenant.
VITE_ENTRA_TENANT_ID=organizations
# Redirect URI registered on the SPA app registration. Defaults to window origin.
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
# API scope exposed by the backend app registration.
VITE_ENTRA_API_SCOPE=api://<api-client-id>/access_as_user
